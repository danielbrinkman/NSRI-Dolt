import sqlalchemy
import pandas as pd

engine = sqlalchemy.create_engine("mysql+mysqlconnector://root:secret2@0.0.0.0:3307/edb")


pd.read_sql("SHOW TABLES;", engine)


users = [
    {
        'username':'dusty',
        'password': 'secret1',
        'p_hash': hash('secret1')
    },
    {
        'username':'dan',
        'password': 'secret2',
        'p_hash': hash('secret2')
    },
    {
        'username':'kirk',
        'password': 'secret3',
        'p_hash': hash('secret3')
    }
]

users = pd.DataFrame(users)


users.to_sql("users", con=engine, if_exists='replace', index=False)


pd.read_sql("SHOW TABLES;", engine)


